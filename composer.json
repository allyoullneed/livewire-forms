{
    "name": "allyouneed/statamic-forms",
    "description": "Tag for rendering Statamic forms dynamically, powered by Livewire 4",
    "keywords": [
        "statamic",
        "cms",
        "forms",
        "laravel",
        "livewire"
    ],
    "require": {
        "livewire/livewire": "^4",
        "illuminate/support": "^12"
    },
    "require-dev": {
        "pestphp/pest": "^4"
    },
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "AllYouNeed\\StatamicForms\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AllYouNeed\\StatamicForms\\FormServiceProvider"
            ]
        }
    },
    "minimum-stability": "beta",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
